  "classification_contract": {
    "scope": "paragraph",
    "single_owner_per_paragraph": true,
    "matches": [],
    "unmatched_paragraph_ids": [],
    "conflicts": [],
    "overall_confidence": 0
  },
  "validation_policy": {
    "enforce_validation": false,
    "min_confidence": 0.8,
    "require_all_required_semantics": false,
    "reject_conflicting_matches": false,
    "reject_order_violations": false,
    "reject_style_violations": false,
    "reject_unmatched_when_required": false
  },
  "style_reference": {
    "page": {
      "paper_size": "A4",
      "margin_top_cm": 2.5,
      "margin_bottom_cm": 2.0,
      "margin_left_cm": 2.8,
      "margin_right_cm": 2.6
    }
  },
  "authoring_guidance": {
    "purpose": "该 sample 与 companion markdown 一起作为固定模板编写规范，既服务人类，也服务 LLM 生成新模板；当前标准模板默认放行任意 DOCX。",
    "coverage_contract": {
      "principle": "模板先覆盖解析器当前真实可见的 paragraph 结构类型，再在此基础上派生业务语义；当前标准模板默认不做结构性或格式性拦截，语义集合主要用于分类、写入映射和未来可选校验。",
      "required_atomic_semantics": [
        "cover_image",
        "document_title",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3",
        "body_paragraph",
        "list_item_level_0",
        "list_item_level_1",
        "table_text",
        "blank_or_unknown"
      ],
      "rules": [
        "如果真实文档会出现某种 paragraph 结构类型，模板应优先提供对应 atomic semantic，或由 blank_or_unknown 合法兜底。",
        "document_title、body_paragraph 等语义在标准模板中默认不承担拦截责任；缺少单独主标题或正文时也允许通过。",
        "用户上传任意 DOCX 默认都允许通过，包括只有标题没有正文、没有主标题、空表格单元格和大量空白段。",
        "标准模板中的 cover_image 统一承接所有非表格图片段落；只要求图片证据与非表格约束，不再限定文首位置。",
        "blank_or_unknown 只吸收空白段、装饰段或 unknown bucket 段落，不能替代表格、列表或正文覆盖。",
        "未知 semantic_key 只会进入 diagnostics，不等于模板已覆盖该段落。",
        "heading_level_n 表示 DOCX 原生标题层级，不表示某种固定编号形态。",
        "如果业务需要区分封面图、正文插图、结果截图或公式图片，应通过 derived_semantics 从 cover_image 继续 refine，而不是新增并行 atomic 图片语义。",
        "只有显式把 validation_policy.enforce_validation 设为 true 时，细分校验开关才会重新生效。"
      ]
    },
    "semantic_layers": {
      "atomic_semantics": "semantic_blocks 负责 paragraph 级单 owner 归属，是模板稳定分类与写入映射的基础；默认不代表必须命中或必须校验。",
      "derived_semantics": "derived_semantics 负责从 atomic semantics 聚合或细分业务语义，不直接改变 paragraph 原子 owner。"
    },
    "recommended_authoring_steps": [
      "先确认目标文档会出现哪些 paragraph 结构类型。",
      "先写 semantic_blocks 覆盖全部结构类型，不直接跳到业务章节名。",
      "用 patch_blocks 为需要执行的语义声明 selector 和 operations。",
      "若存在文档级布局或样式定义，使用非 paragraph selector 单独建 block，不必硬塞进 atomic semantic。",
      "只有在 atomic 层稳定后，才添加 derived_semantics。",
      "如果业务确实需要拦截，再显式把 validation_policy.enforce_validation 设为 true 并补齐严格规则。"
    ]
  },
  "development_notes": {
    "do_not_scan_from_frontend": true,
    "intended_location": "docs/examples",
    "companion_doc": "docs/examples/fixed-template-contract.sample.md",
    "usage": "复制到 templates 根目录后，先保留结构全覆盖集合，再按业务需要裁剪结构语义、补充派生语义和具体 patch block。"
  },
  "runtime_notes": {
    "classification_reads": [
      "semantic_blocks",
      "layout_rules"
    ],
    "patch_blocks_supported_selectors": [
      "document/paragraph",
      "document/run",
      "document/section",
      "styles/style",
      "numbering/numbering_level",
      "settings/settings_node",
      "by_part_path/*"
    ],
    "patch_blocks_supported_aliases": [
      "set_run_style",
      "set_paragraph_style",
      "set_section_layout",
      "set_style_definition",
      "set_numbering_level",
      "set_settings_flag"
    ],
    "patch_blocks_supported_primitives": [
      "set_attr",
      "remove_attr",
      "set_text",
      "remove_node",
      "ensure_node",
      "replace_node_xml"
    ],
    "compatibility_notes": [
      "`operation_blocks` 仍可作为过渡输入保留，但 public sample 以 `patch_blocks` 为唯一主写入契约。",
      "`language_font_overrides` 仍走兼容层追加 run 级 patch，不作为本 sample 的主契约展示。"
    ],
    "notes": [
      "document_page_layout 使用 section selector 编译为文档级 patch，不参与 paragraph 级分类。",
      "blank_or_unknown 在该 sample 中只承担分类兜底，不强制声明写入 block。",
      "编写新模板时，应优先保证 atomic semantics 覆盖所有当前解析器可见的 paragraph 元素种类。"
    ]
  }
}
