{
  "template_meta": {
    "id": "fixed_template_structural_sample",
    "name": "固定模板通用结构语义示例",
    "version": "0.5.0",
    "schema_version": "1.0",
    "description": "面向固定模板编写规范与联调的通用结构语义母版，按解析器当前可见的段落结构建模，并显式展示统一图片段落、结构覆盖与语义继承机制。",
    "locale": "zh-CN",
    "author": "Codex",
    "tags": [
      "sample",
      "development",
      "fixed-template",
      "structural-semantics"
    ]
  },
  "semantic_blocks": [
    {
      "key": "cover_image",
      "label": "图片段落",
      "description": "匹配任意具备图片证据的段落；可为纯图片，也可为图片加少量图号或说明文字，不替代文本标题。",
      "examples": [
        "（图片段落）",
        "图7.1.1 模型输出截图"
      ],
      "negative_examples": [
        "自然语言处理课程作业评分细则",
        "一、课程目标"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "document_title",
      "label": "文档主标题",
      "description": "仅匹配文首文本主标题，不吞并图片封面或正文中的各级章节标题。",
      "examples": [
        "自然语言处理课程作业评分细则"
      ],
      "negative_examples": [
        "一、课程目标",
        "（一）实验内容"
      ],
      "required": false,
      "multiple": false
    },
    {
      "key": "heading_level_1",
      "label": "一级结构标题",
      "description": "DOCX 原生一级标题；以解析结果中的 heading_level=1 为准，不等于某种固定编号形态。",
      "examples": [
        "一、课程目标",
        "第一章 总则"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_2",
      "label": "二级结构标题",
      "description": "DOCX 原生二级标题；以解析结果中的 heading_level=2 为准，不等于某种固定编号形态。",
      "examples": [
        "（一）实验内容",
        "3.1 实验数据集"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_3",
      "label": "三级结构标题",
      "description": "DOCX 原生三级标题；以解析结果中的 heading_level=3 为准，不等于某种固定编号形态。",
      "examples": [
        "1. 词法分析",
        "3.1.1 数据来源"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "body_paragraph",
      "label": "正文段落",
      "description": "普通正文段落，不在表格内，也不是列表项。",
      "examples": [
        "学生需在报告中说明实验环境、方法、结果与结论。"
      ],
      "required": true,
      "multiple": true
    },
    {
      "key": "list_item_level_0",
      "label": "一级列表项",
      "description": "解析器识别为 list_item 且 list_level=0 的段落。",
      "examples": [
        "- 提交 PDF 报告与源代码链接"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "list_item_level_1",
      "label": "二级列表项",
      "description": "解析器识别为 list_item 且 list_level=1 的段落。",
      "examples": [
        "  - 报告需包含实验截图与结果分析"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "table_text",
      "label": "表格文本",
      "description": "表格单元格中的段落文本；当前不区分表头、表体或分值列。",
      "examples": [
        "指标 | 说明 | 分值"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "blank_or_unknown",
      "label": "空白或未知段落",
      "description": "用于承接空白段、装饰分隔符或当前无法稳定归类的段落，避免严格模式下系统性 unmatched。",
      "examples": [
        "（空白段）",
        "——"
      ],
      "required": false,
      "multiple": true
    }
  ],
  "derived_semantics": [
    {
      "key": "body_content",
      "label": "正文",
      "mode": "aggregate",
      "inherits_from": [
        "body_paragraph",
        "list_item_level_0",
        "list_item_level_1"
      ],
      "examples": [
        "学生需在报告中说明实验环境、方法、结果与结论。",
        "- 提交 PDF 报告与源代码链接"
      ],
      "operation": {
        "text_style": {
          "font_name": "仿宋_GB2312",
          "font_size_pt": 16
        },
        "paragraph_style": {
          "paragraph_alignment": "justify"
        }
      }
    },
    {
      "key": "copy_to_authority",
      "label": "抄送机关",
      "mode": "refine",
      "inherits_from": [
        "body_paragraph",
        "list_item_level_0",
        "list_item_level_1"
      ],
      "examples": [
        "抄送：市委办公室、市政府办公室。"
      ],
      "text_hints": [
        "抄送",
        "送："
      ],
      "negative_examples": [
        "现将",
        "实验内容"
      ],
      "operation": {
        "text_style": {
          "font_name": "KaiTi"
        },
        "paragraph_style": {
          "paragraph_alignment": "left"
        }
      }
    }
  ],
  "layout_rules": {
    "global_rules": {
      "document_scope": "full_document",
      "ordering": [
        "document_title",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3"
      ],
      "numbering_patterns": [
        "^[一二三四五六七八九十]+、$",
        "^（[一二三四五六七八九十]+）$",
        "^\\d+[.)．、]$",
        "^[(（]\\d+[)）]$"
      ],
      "allow_unclassified_paragraphs": false
    },
    "semantic_rules": [
      {
        "semantic_key": "cover_image",
        "style_hints": {
          "allow_empty_text": true,
          "require_image": true,
          "must_not_be_in_table": true,
          "preferred_role": [
            "unknown",
            "body",
            "title"
          ]
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 200
        }
      },
      {
        "semantic_key": "document_title",
        "position_hints": [
          "first_non_blank",
          "near_top"
        ],
        "style_hints": {
          "allow_empty_text": true,
          "preferred_role": [
            "heading",
            "title"
          ],
          "preferred_bucket_type": [
            "heading",
            "title"
          ],
          "must_not_be_in_table": true,
          "must_not_match": [
            "heading_level_1",
            "heading_level_2",
            "heading_level_3"
          ]
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 1
        }
      },
      {
        "semantic_key": "heading_level_1",
        "style_hints": {
          "allow_empty_text": true,
          "role": "heading",
          "heading_level": 1,
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 50
        }
      },
      {
        "semantic_key": "heading_level_2",
        "style_hints": {
          "allow_empty_text": true,
          "role": "heading",
          "heading_level": 2,
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 80
        }
      },
      {
        "semantic_key": "heading_level_3",
        "style_hints": {
          "allow_empty_text": true,
          "role": "heading",
          "heading_level": 3,
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 120
        }
      },
      {
        "semantic_key": "body_paragraph",
        "numbering_patterns": [
          "^\\d+\\.\\d+(?:\\.\\d+)*[)）、．。、]?$"
        ],
        "style_hints": {
          "allow_empty_text": true,
          "role": "body",
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 1,
          "max_occurs": 500
        }
      },
      {
        "semantic_key": "list_item_level_0",
        "style_hints": {
          "allow_empty_text": true,
          "role": "list_item",
          "list_level": 0,
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 200
        }
      },
      {
        "semantic_key": "list_item_level_1",
        "style_hints": {
          "allow_empty_text": true,
          "role": "list_item",
          "list_level": 1,
          "must_not_be_in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 200
        }
      },
      {
        "semantic_key": "table_text",
        "style_hints": {
          "allow_empty_text": true,
          "preferred_role": [
            "table_text",
            "body",
            "unknown"
          ],
          "in_table": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 500
        }
      },
      {
        "semantic_key": "blank_or_unknown",
        "text_hints": [
          "空文本",
          "装饰分隔符",
          "无法稳定归入其他语义"
        ],
        "style_hints": {
          "preferred_role": [
            "unknown"
          ],
          "allow_empty_text": true
        },
        "occurrence": {
          "min_occurs": 0,
          "max_occurs": 200
        }
      }
    ]
  },
