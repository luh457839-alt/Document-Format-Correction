  "classification_contract": {
    "scope": "paragraph",
    "single_owner_per_paragraph": true,
    "matches": [],
    "unmatched_paragraph_ids": [],
    "conflicts": [],
    "overall_confidence": 0
  },
  "validation_policy": {
    "enforce_validation": false,
    "min_confidence": 0.8,
    "require_all_required_semantics": false,
    "reject_conflicting_matches": false,
    "reject_order_violations": false,
    "reject_style_violations": false,
    "reject_unmatched_when_required": false
  },
  "style_reference": {
    "page": {
      "paper_size": "A4",
      "margin_top_cm": 2.5,
      "margin_bottom_cm": 2.0,
      "margin_left_cm": 2.8,
      "margin_right_cm": 2.6
    }
  },
  "authoring_guidance": {
    "purpose": "该 sample 与 companion markdown 一起作为固定模板编写规范，既服务人类，也服务 LLM 生成新模板；当前标准模板默认放行任意 DOCX。",
    "coverage_contract": {
      "principle": "模板先覆盖解析器当前真实可见的 paragraph 结构类型，再在此基础上派生业务语义；当前标准模板默认不做结构性或格式性拦截，语义集合主要用于分类、写入映射和未来可选校验。",
      "required_atomic_semantics": [
        "cover_image",
        "document_title",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3",
        "body_paragraph",
        "list_item_level_0",
        "list_item_level_1",
        "table_text",
        "blank_or_unknown"
      ],
      "rules": [
        "如果真实文档会出现某种 paragraph 结构类型，模板应优先提供对应 atomic semantic，或由 blank_or_unknown 合法兜底。",
        "document_title、body_paragraph 等语义在标准模板中默认不承担拦截责任；缺少单独主标题或正文时也允许通过。",
        "用户上传任意 DOCX 默认都允许通过，包括只有标题没有正文、没有主标题、空表格单元格和大量空白段。",
        "标准模板中的 cover_image 统一承接所有非表格图片段落；只要求图片证据与非表格约束，不再限定文首位置。",
        "blank_or_unknown 只吸收空白段、装饰段或 unknown bucket 段落，不能替代列表、表格或正文覆盖。",
        "blank_or_unknown 不应吸收任何有图片证据的段落。",
        "未知 semantic_key 只会进入 diagnostics，不等于模板已覆盖该段落。",
        "heading_level_n 表示 DOCX 原生标题层级，不表示某种固定编号形态。",
        "如果业务需要区分封面图、正文插图、结果截图或公式图片，应通过 derived_semantics 从 cover_image 继续 refine，而不是新增并行 atomic 图片语义。",
        "只有显式把 validation_policy.enforce_validation 设为 true 时，细分校验开关才会重新生效。"
      ]
    },
    "semantic_layers": {
      "atomic_semantics": "semantic_blocks 负责 paragraph 级单 owner 归属，是模板稳定分类与写入映射的基础；默认不代表必须命中或必须校验。",
      "derived_semantics": "derived_semantics 负责从 atomic semantics 聚合或细分业务语义，不直接改变 paragraph 原子 owner。"
    },
    "inheritance_mechanism": {
      "aggregate": {
        "definition": "把多个 atomic semantics 聚合成一个更符合用户理解的业务语义。",
        "allowed_for": [
          "统一正文视图",
          "统一样式写入视图",
          "减少多个原子语义重复配置相同操作"
        ],
        "constraints": [
          "不得改变原子 paragraph owner。",
          "只能聚合已有 atomic semantics。",
          "若存在 refine 子语义，写入规划阶段应从 aggregate 父集合中裁掉子集合以避免重复写入。"
        ]
      },
      "refine": {
        "definition": "在父语义候选集合中再细分出更具体的业务语义。",
        "allowed_for": [
          "抄送机关",
          "落款说明",
          "正文内部特殊业务段"
        ],
        "constraints": [
          "候选集合必须来自已命中的 atomic semantics。",
          "结果必须是父集合的子集，不能凭空新增 paragraph owner。",
          "应优先结合 text_hints、negative_examples 等稳定信号缩小命中范围。"
        ]
      }
    },
    "recommended_authoring_steps": [
      "先确认目标文档会出现哪些 paragraph 结构类型。",
      "先写 semantic_blocks 覆盖全部结构类型，不直接跳到业务章节名。",
      "为每个 atomic semantic 写 semantic_rules 与 operation_blocks。",
      "标准模板默认允许空文本，保留 blank_or_unknown 作为宽松兜底。",
      "只有在 atomic 层稳定后，才添加 derived_semantics。",
      "检查每个 derived semantic 是否都能明确追溯到父 atomic semantics。",
      "如果业务确实需要拦截，再显式把 validation_policy.enforce_validation 设为 true 并补齐严格规则。"
    ],
    "llm_checklist": [
      "默认模板不要把任意缺失、顺序、编号、样式问题直接当作失败条件。",
      "不要只写 title/body 两类就试图覆盖完整文档。",
      "不要把尚未稳定可见的业务概念直接写成 atomic semantic。",
      "不要遗漏 table_text、list_item_level_* 或 blank_or_unknown。",
      "不要复用 heading_level_n 去表达编号样式；如果业务真要按编号形态区分，请新增独立语义。",
      "不要让 derived semantics 绕过 atomic semantics 直接争夺 paragraph owner。",
      "只有在用户明确要求严格模式时，才启用 enforce_validation=true 并按需打开细分校验开关。"
    ]
  },
  "development_notes": {
    "do_not_scan_from_frontend": true,
    "intended_location": "docs/examples",
    "companion_doc": "docs/examples/fixed-template-contract.sample.md",
    "usage": "复制到 templates 根目录后，先保留结构全覆盖集合，再按业务需要裁剪结构语义、补充派生语义和具体样式。"
  },
  "runtime_notes": {
    "classification_reads": [
      "semantic_blocks",
      "layout_rules"
    ],
    "write_planner_supported_fields": [
      "text_style.font_name",
      "text_style.font_size_pt",
      "text_style.font_color",
      "text_style.is_bold",
      "text_style.is_italic",
      "text_style.is_underline",
      "text_style.is_strike",
      "text_style.highlight_color",
      "text_style.is_all_caps",
      "operation_blocks.language_font_overrides.zh.font_name",
      "operation_blocks.language_font_overrides.en.font_name",
      "paragraph_style.line_spacing",
      "paragraph_style.paragraph_alignment"
    ],
    "notes": [
      "style_reference.page 仅作为文档级规格参考，不参与 paragraph 级分类。",
      "blank_or_unknown 的 operation_block 为 no-op，用于严格模板下吸收空白段和装饰段。",
      "language_font_overrides 在 paragraph 样式计划之后执行，仅对命中的中英文 run 片段覆盖 font_name。",
      "derived_semantics 是业务表达层，不改变 atomic semantics 的 paragraph 单 owner 契约。",
      "编写新模板时，应优先保证 atomic semantics 覆盖所有当前解析器可见的 paragraph 元素种类。"
    ]
  }
}
