{
  "template_meta": {
    "id": "official_document_patchdsl_template",
    "name": "公文式固定模板（Patch DSL）",
    "version": "0.7.0",
    "schema_version": "2.0",
    "description": "按公文式固定排版要求编写的 Patch DSL 模板，主路径使用 patch_blocks，默认放行，不把缺项、顺序、编号或样式偏差当作失败。",
    "locale": "zh-CN",
    "author": "Codex",
    "tags": [
      "sample",
      "development",
      "fixed-template",
      "official-document",
      "patch-dsl"
    ]
  },
  "semantic_blocks": [
    {
      "key": "document_title",
      "label": "文档标题",
      "description": "文首主标题，使用方正小标宋简体二号，居中排版。",
      "examples": [
        "关于开展专项检查工作的通知"
      ],
      "negative_examples": [
        "某某单位",
        "一、总体要求"
      ],
      "required": false,
      "multiple": false
    },
    {
      "key": "organization_name",
      "label": "单位名称",
      "description": "标题下方的单位名称或发文机关名称，通常单独成行并居中。",
      "examples": [
        "某某市人民政府办公室"
      ],
      "negative_examples": [
        "关于开展专项检查工作的通知",
        "现将有关事项通知如下。"
      ],
      "required": false,
      "multiple": false
    },
    {
      "key": "blank_or_unknown",
      "label": "空白或未知段落",
      "description": "用于吸收标题与单位名称后的空一行、装饰分隔符以及当前无法稳定细分的段落。",
      "examples": [
        "（空白段）",
        "——"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "body_paragraph",
      "label": "正文段落",
      "description": "普通正文段落，使用仿宋_GB2312 三号、28 磅固定行距、首行缩进 2 字符。",
      "examples": [
        "现将有关事项通知如下。"
      ],
      "negative_examples": [
        "一、总体要求",
        "表 1 项目进度安排"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_1",
      "label": "一级标题",
      "description": "公文一级标题，通常保留文本编号，如“一、”。",
      "examples": [
        "一、总体要求"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_2",
      "label": "二级标题",
      "description": "公文二级标题，通常保留文本编号，如“（一）”。",
      "examples": [
        "（一）组织领导"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_3",
      "label": "三级标题",
      "description": "公文三级标题，通常保留文本编号，如“1.”，字体为加粗仿宋。",
      "examples": [
        "1. 任务分工"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "heading_level_4",
      "label": "四级标题",
      "description": "公文四级标题，通常保留文本编号，如“（1）”，字体为不加粗仿宋。",
      "examples": [
        "（1）材料准备"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "table_caption",
      "label": "表题",
      "description": "表格上方的表题，使用黑体小四、居中，前后各留 0.5 行。",
      "examples": [
        "表 1 项目进度安排"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "table_header",
      "label": "表头",
      "description": "表格首行表头单元格文本，使用黑体五号。",
      "examples": [
        "序号",
        "项目名称",
        "完成时限"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "table_body",
      "label": "表体",
      "description": "表格正文单元格文本，中文宋体五号，单元格转行时 18 磅固定行距。",
      "examples": [
        "1",
        "2026-04-25",
        "组织实施"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "figure",
      "label": "插图",
      "description": "图片或图形所在段落，不承担标题文本语义。",
      "examples": [
        "（插图段落）"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "figure_caption",
      "label": "图题",
      "description": "插图下方图题，样式与表题一致，但位置在图下方。",
      "examples": [
        "图 1 工作流程图"
      ],
      "required": false,
      "multiple": true
    },
    {
      "key": "page_number",
      "label": "页码",
      "description": "页码文本规范，要求宋体小四，格式如“-5-”。",
      "examples": [
        "-5-"
      ],
      "required": false,
      "multiple": true
    }
  ],
  "derived_semantics": [
    {
      "key": "blank_line_after_front_matter",
      "label": "前置信息后的空行",
      "mode": "refine",
      "inherits_from": [
        "blank_or_unknown"
      ],
      "examples": [
        "（单位名称之后的空一行）"
      ],
      "text_hints": [
        "空白段",
        "标题和单位名称之后的过渡空行"
      ],
      "negative_examples": [
        "——",
        "分页分隔空白"
      ],
      "operation": {
        "text_style": {},
        "paragraph_style": {}
      }
    },
    {
      "key": "body_content",
      "label": "正文内容",
      "mode": "aggregate",
      "inherits_from": [
        "body_paragraph",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3",
        "heading_level_4",
        "table_caption",
        "table_header",
        "table_body",
        "figure",
        "figure_caption"
      ],
      "examples": [
        "一、总体要求",
        "现将有关事项通知如下。",
        "表 1 项目进度安排",
        "图 1 工作流程图"
      ],
      "operation": {
        "text_style": {
          "font_name": "仿宋_GB2312",
          "font_size_pt": 16,
          "is_bold": false
        },
        "paragraph_style": {
          "paragraph_alignment": "justify",
          "line_spacing": {
            "mode": "exact",
            "pt": 28
          },
          "first_line_indent_chars": 2
        }
      }
    }
  ],
  "layout_rules": {
    "global_rules": {
      "document_scope": "full_document",
      "ordering": [
        "document_title",
        "organization_name",
        "blank_or_unknown",
        "body_paragraph",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3",
        "heading_level_4",
        "table_caption",
        "table_header",
        "table_body",
        "figure",
        "figure_caption",
        "page_number"
      ],
      "allow_unclassified_paragraphs": false,
      "page_layout_reference": {
        "paper_size": "A4",
        "margin_top_cm": 3.7,
        "margin_bottom_cm": 3.5,
        "margin_left_cm": 2.8,
        "margin_right_cm": 2.6
      }
    },
