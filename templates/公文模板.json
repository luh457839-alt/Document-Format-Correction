  "authoring_guidance": {
    "purpose": "该模板是可直接复制裁剪的公文式 Patch DSL 样板，强调格式优先、默认放行。",
    "coverage_contract": {
      "principle": "语义细分服务于分类、写入映射和后续扩展，不默认把缺项、顺序、编号或样式偏差当作失败。",
      "required_atomic_semantics": [
        "document_title",
        "organization_name",
        "blank_or_unknown",
        "body_paragraph",
        "heading_level_1",
        "heading_level_2",
        "heading_level_3",
        "heading_level_4",
        "table_caption",
        "table_header",
        "table_body",
        "figure",
        "figure_caption",
        "page_number"
      ],
      "rules": [
        "缺单位名称、缺表题、缺图题、缺页码文本时，默认放行模板仍允许通过。",
        "标题、单位名称与正文之间的空一行通过 blank_or_unknown + blank_line_after_front_matter 表达，不单独发明运行时必拦截规则。",
        "表头与表体先在模板规范层面分开；若当前观察链路无法稳定区分，允许保留为草案字段，不直接拦截。",
        "figure 语义只承接图片段落本身，figure_caption 单独承接图下文字说明。",
        "page_number 语义记录页码样式要求，不等于当前运行时已经自动排版成功。"
      ]
    },
    "fixed_front_matter": {
      "ordering": [
        "document_title",
        "organization_name",
        "blank_line_after_front_matter",
        "body_content"
      ],
      "notes": [
        "固定前部结构按“标题 -> 单位名称 -> 空一行 -> 正文内容”表达。",
        "layout_rules.global_rules.ordering 仍只对 atomic semantics 建模；derived semantics 用于补足 blank_line_after_front_matter 与 body_content 的业务表达。"
      ]
    },
    "numbering_policy": {
      "preserve_text_numbering": true,
      "rely_on_word_auto_numbering": false,
      "authoring_requirement": "取消自动生成格式，编号作为正文文本保留，不依赖 Word 自动编号。",
      "notes": [
        "一级到四级标题编号全部按文本内容保留。",
        "默认放行模式下不因编号缺失、层级不规范或编号样式不一致而拦截。"
      ]
    },
    "table_and_figure_policy": {
      "table_caption_position": "above_table",
      "figure_caption_position": "below_figure",
      "caption_spacing_policy": "表题、图题均按前后 0.5 行写入 paragraph_style.space_before_pt = 14 和 space_after_pt = 14。"
    }
  },
  "runtime_notes": {
    "patch_blocks_supported_aliases": [
      "set_run_style",
      "set_paragraph_style",
      "set_section_layout"
    ],
    "notes": [
      "style_reference.page.header_distance_cm、footer_distance_cm 与 page_number_layout 当前作为规范保留字段，不参与 set_section_layout payload 生成。",
      "table_body 中的数字字体 Times New Roman 仍属于说明性目标；若需要中英文 run 级差异化字体覆写，当前应结合兼容层能力处理。",
      "page_number 语义用于记录页码样式要求，当前模板不直接承诺自动生成“奇偶页镜像外侧”的页码布局。"
    ]
  }
}
