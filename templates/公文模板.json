  "patch_blocks": [
    {
      "semantic_key": "document_page_layout",
      "selector": {
        "part": "document",
        "scope": "section",
        "match": {
          "section_index": 0
        }
      },
      "operations": [
        {
          "type": "set_section_layout",
          "section_layout": {
            "paper_size": "A4",
